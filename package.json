{
  "name": "beemora-dashboard",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "server": "node server.js",
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "concurrently \"node server.js\" \"vite\" --names api,vite --prefix-colors blue,green",
    "dev:frontend": "vite",
    "build": "vite build",
    "build:prod": "cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "deploy": "bash deploy.sh update",
    "deploy:full": "bash deploy.sh full",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop beemora-api",
    "pm2:logs": "pm2 logs beemora-api"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "multer": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.10.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.0",
    "vite": "^5.4.2"
  }
}
