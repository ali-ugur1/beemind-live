# ╔══════════════════════════════════════════════════════════════════╗
# ║  BeeMora — Environment Variables                               ║
# ║  Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin      ║
# ║  cp .env.example .env                                          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Server ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── JWT Authentication ────────────────────────────────────────────
# ⚠️ Production'da mutlaka değiştirin! Aşağıdaki komutla üretin:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# ── CORS ──────────────────────────────────────────────────────────
# Virgülle ayrılmış izin verilen originler
# Örnek: https://beemora.app,https://www.beemora.app
CORS_ORIGINS=https://yourdomain.com

# ── ESP32 Sensor API Key ─────────────────────────────────────────
# ESP32 cihazlarından gelen verileri korumak için opsiyonel API key
# Boş bırakılırsa sensor-data endpoint'i açık kalır
ESP_API_KEY=

# ── Web Push (VAPID) ─────────────────────────────────────────────
# VAPID key üretmek için: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:beemoraproject@gmail.com

# ── Data Limits ───────────────────────────────────────────────────
# Maksimum sensör kaydı sayısı (eski veriler otomatik silinir)
MAX_SENSOR_RECORDS=50000

# ── Frontend (Vite) ──────────────────────────────────────────────
# Production'da boş bırakın (aynı origin üzerinden sunulur)
# Geliştirme sırasında: http://localhost:3001
VITE_API_URL=
