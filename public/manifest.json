      "type": "image/png",
      "form_factor": "wide",
      "label": "BeeMora masaüstü kontrol paneli"
    },
    {
      "src": "/screenshots/analytics-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "AI destekli analiz ekranı"
    }
  ],
  "shortcuts": [
    {
      "name": "Kontrol Paneli",
      "short_name": "Panel",
      "description": "Kovan izleme paneline git",
      "url": "/panel?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-dashboard.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Kovanlarım",
      "short_name": "Kovanlar",
      "description": "Tüm kovanları listele",
      "url": "/hives?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-hives.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Uyarılar",
      "short_name": "Uyarılar",
      "description": "Aktif uyarı ve bildirimler",
      "url": "/alerts?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-alerts.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Yeni Kovan Ekle",
      "short_name": "Ekle",
      "description": "Hızlı kovan kaydı oluştur",
      "url": "/hives/new?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-add.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+beemora",
      "url": "/open?data=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "photo",
          "accept": ["image/jpeg", "image/png", "image/webp"]
        }
      ]
    }
  },
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  }
}
