{
  "id": "/",
  "name": "BeeMora - Akıllı Arıcılık İzleme Sistemi",
  "short_name": "BeeMora",
  "description": "AI destekli IoT kovan izleme ve yönetim sistemi. Kovanlarınızı 7/24 izleyin, sıcaklık, nem ve ağırlık verilerini anlık takip edin, koloni kayıplarını önleyin.",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "background_color": "#0a0a0f",
  "theme_color": "#4f46e5",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "tr",
  "dir": "ltr",
  "categories": ["agriculture", "productivity", "utilities", "business"],
  "prefer_related_applications": false,
